generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Device {
  imei      String    @id
  name      String?
  apiKey    String    @unique @default(uuid()) // Kept for legacy/hardware auth if needed
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  // Relation to User (Owner)
  userId    Int?
  user      User?     @relation(fields: [userId], references: [id])

  readings Reading[]

  @@map("devices")
}

model Reading {
  id          Int      @id @default(autoincrement())
  temperature Float
  humidity    Float?
  voltage     Float?
  packetIndex Int?
  timestamp   DateTime @default(now())
  deviceImei  String

  device Device @relation(fields: [deviceImei], references: [imei], onDelete: Cascade)

  @@index([deviceImei, timestamp(sort: Desc)])
  @@map("readings")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("CLIENT") // "ADMIN", "CLIENT"
  createdAt DateTime @default(now())

  devices   Device[]

  @@map("users")
}
