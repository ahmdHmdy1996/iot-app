# PostgreSQL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/iot_monitoring?schema=public"

# Server Ports
HTTP_PORT=3000
TCP_PORT=8899

# Environment
NODE_ENV=development

# Admin JWT Auth (single admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password
JWT_SECRET=your-long-random-jwt-secret
SYSTEM_API_KEY=your_master_system_api_key_here
CATERFLOW_WEBHOOK_URL=https://api.caterflow.com/v1/webhooks/iot
